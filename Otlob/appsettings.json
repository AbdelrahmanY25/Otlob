{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/logs-.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "Otlob"
    }
  },
  "JWT": {
    "Issure": "otlob",
    "Audience": "otlob Mobile Users",
    "ExpiryMinutes": 30
  },
  "MailSettings": {
    "Email": "justotlob@gmail.com",
    "DisplayName": "Otlob",
    "Host": "smtp.gmail.com",
    "Port": 465
  }
}