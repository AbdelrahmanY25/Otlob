@using Microsoft.AspNetCore.Identity
@using Otlob.Core.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a style=" color: #e9b226;" id="manage" class="nav-link" asp-area="" asp-page="/Account/Manage/Index" title="Manage">Hello @UserManager.GetUserName(User)!</a>
    </li>
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-area="" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button style=" color: #e9b226;" id="logout" type="submit" class="nav-link btn btn-link border-0">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a style=" color: #e9b226;" class="nav-link" id="register" asp-area="" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
         <a style=" color: #e9b226;" class="nav-link" id="login" asp-area="" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
