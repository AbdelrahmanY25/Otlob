@model AdvertisementResponse

@{
    ViewData["Title"] = "Payment Successful";
}

<link rel="stylesheet" href="~/css/advertisements.css" asp-append-version="true" />

@{
}

<div class="ads-success-page">
    <div class="ads-success-card">
        <div class="ads-success-icon">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        
        <h1 class="ads-success-title">Payment Successful!</h1>
        <p class="ads-success-subtitle">Your advertisement has been submitted for review</p>

        <div class="ads-success-details">
            <div class="ads-success-row">
                <span>Advertisement</span>
                <strong>@Model.Title</strong>
            </div>
            <div class="ads-success-row">
                <span>Plan</span>
                <span class="ads-plan-badge">@Model.PlanName</span>
            </div>
            <div class="ads-success-row">
                <span>Amount Paid</span>
                <strong class="text-success">@Model.PlanPrice.ToString("N0") EGP</strong>
            </div>
            <div class="ads-success-row">
                <span>Status</span>
                <span class="ads-status-badge status-pending">Pending Review</span>
            </div>
        </div>

        <div class="ads-success-message">
            <i class="bi bi-info-circle"></i>
            <p>Your advertisement is now pending review by our admin team. You will be notified once it's approved. The advertisement will go live on <strong>@Model.StartDate.ToString("MMMM dd, yyyy")</strong> after approval.</p>
        </div>

        <div class="ads-success-actions">
            <a asp-action="Details" asp-route-id="@Model.Id" class="ads-btn ads-btn-primary">
                <i class="bi bi-eye"></i>
                View Advertisement
            </a>
            <a asp-action="Index" class="ads-btn ads-btn-secondary">
                <i class="bi bi-list"></i>
                All Advertisements
            </a>
        </div>
    </div>
</div>
