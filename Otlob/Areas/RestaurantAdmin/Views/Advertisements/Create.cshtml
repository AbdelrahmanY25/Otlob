@model CreateAdvertisementRequest

@{
    ViewData["Title"] = "Create Advertisement";
}

<link rel="stylesheet" href="~/css/advertisements.css" asp-append-version="true" />

@{
    var plans = ViewBag.Plans as List<AdvertisementPlanResponse> ?? new List<AdvertisementPlanResponse>();
}

<div class="ads-create-page">
    <!-- Header -->
    <div class="ads-create-header">
        <a asp-action="Index" class="ads-back-btn">
            <i class="bi bi-arrow-left"></i>
            Back to Advertisements
        </a>
        <h1 class="ads-create-title">
            <i class="bi bi-megaphone-fill"></i>
            Create New Advertisement
        </h1>
        <p class="ads-create-subtitle">Promote your restaurant and reach more customers</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="ads-create-form">
        @Html.AntiForgeryToken()

        <div class="ads-form-grid">
            <!-- Left Column - Ad Details -->
            <div class="ads-form-section">
                <h3 class="ads-section-title">
                    <i class="bi bi-card-text"></i>
                    Advertisement Details
                </h3>

                <div class="ads-form-group">
                    <label asp-for="Title" class="ads-form-label">Title (English) <span class="required">*</span></label>
                    <input asp-for="Title" class="ads-form-input" placeholder="Enter advertisement title" />
                    <span asp-validation-for="Title" class="ads-validation-error"></span>
                </div>

                <div class="ads-form-group">
                    <label asp-for="TitleAr" class="ads-form-label">Title (Arabic) <span class="required">*</span></label>
                    <input asp-for="TitleAr" class="ads-form-input" dir="rtl" placeholder="أدخل عنوان الإعلان" />
                    <span asp-validation-for="TitleAr" class="ads-validation-error"></span>
                </div>

                <div class="ads-form-group">
                    <label asp-for="Description" class="ads-form-label">Description (English) <span class="required">*</span></label>
                    <textarea asp-for="Description" class="ads-form-textarea" rows="3" placeholder="Describe your advertisement..."></textarea>
                    <span asp-validation-for="Description" class="ads-validation-error"></span>
                </div>

                <div class="ads-form-group">
                    <label asp-for="DescriptionAr" class="ads-form-label">Description (Arabic) <span class="required">*</span></label>
                    <textarea asp-for="DescriptionAr" class="ads-form-textarea" dir="rtl" rows="3" placeholder="وصف الإعلان..."></textarea>
                    <span asp-validation-for="DescriptionAr" class="ads-validation-error"></span>
                </div>

                <div class="ads-form-group">
                    <label asp-for="ImageUrl" class="ads-form-label">Image URL <span class="required">*</span></label>
                    <input asp-for="ImageUrl" class="ads-form-input" placeholder="https://example.com/image.jpg" />
                    <span asp-validation-for="ImageUrl" class="ads-validation-error"></span>
                    <small class="ads-form-hint">Enter the URL of your advertisement image (recommended size: 1200x630px)</small>
                </div>

                <div class="ads-form-group">
                    <label asp-for="StartDate" class="ads-form-label">Start Date <span class="required">*</span></label>
                    <input asp-for="StartDate" type="date" class="ads-form-input" min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="StartDate" class="ads-validation-error"></span>
                    <small class="ads-form-hint">Your advertisement will go live on this date after approval</small>
                </div>
            </div>

            <!-- Right Column - Plan Selection -->
            <div class="ads-form-section">
                <h3 class="ads-section-title">
                    <i class="bi bi-tag"></i>
                    Choose Your Plan
                </h3>

                <div class="ads-plans-container">
                    @foreach (var plan in plans.OrderBy(p => p.DisplayOrder))
                    {
                        <label class="ads-plan-card @(plan.Id == 2 ? "popular" : "")">
                            <input type="radio" asp-for="AdvertisementPlanId" value="@plan.Id" class="ads-plan-radio" />
                            <div class="ads-plan-content">
                                @if (plan.Id == 2)
                                {
                                    <span class="ads-plan-popular-badge">Most Popular</span>
                                }
                                <h4 class="ads-plan-name">@plan.Name</h4>
                                <p class="ads-plan-name-ar">@plan.NameAr</p>
                                <div class="ads-plan-price">
                                    <span class="ads-plan-amount">@plan.PricePerMonth.ToString("N0")</span>
                                    <span class="ads-plan-currency">EGP</span>
                                    <span class="ads-plan-period">/ @plan.DurationInDays days</span>
                                </div>
                                <p class="ads-plan-description">@plan.Description</p>
                                <ul class="ads-plan-features">
                                    @if (plan.Id == 1)
                                    {
                                        <li><i class="bi bi-check"></i> Sponsored badge</li>
                                        <li><i class="bi bi-check"></i> Visible in search results</li>
                                        <li><i class="bi bi-check"></i> Basic analytics</li>
                                    }
                                    else if (plan.Id == 2)
                                    {
                                        <li><i class="bi bi-check"></i> Priority placement</li>
                                        <li><i class="bi bi-check"></i> Home page carousel</li>
                                        <li><i class="bi bi-check"></i> Advanced analytics</li>
                                        <li><i class="bi bi-check"></i> Higher visibility</li>
                                    }
                                    else if (plan.Id == 3)
                                    {
                                        <li><i class="bi bi-check"></i> Top position</li>
                                        <li><i class="bi bi-check"></i> Featured styling</li>
                                        <li><i class="bi bi-check"></i> All pages display</li>
                                        <li><i class="bi bi-check"></i> Premium analytics</li>
                                        <li><i class="bi bi-check"></i> Maximum exposure</li>
                                    }
                                </ul>
                            </div>
                        </label>
                    }
                </div>
                <span asp-validation-for="AdvertisementPlanId" class="ads-validation-error"></span>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="ads-form-actions">
            <a asp-action="Index" class="ads-btn ads-btn-secondary">
                <i class="bi bi-x-lg"></i>
                Cancel
            </a>
            <button type="submit" class="ads-btn ads-btn-primary">
                <i class="bi bi-megaphone"></i>
                Create Advertisement
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Image preview functionality
        document.getElementById('ImageUrl').addEventListener('change', function() {
            const url = this.value;
            // Could add image preview functionality here
        });
    </script>
}
