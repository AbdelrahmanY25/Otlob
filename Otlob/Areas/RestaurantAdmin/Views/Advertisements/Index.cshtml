@model IEnumerable<AdvertisementResponse>

@{
    ViewData["Title"] = "My Advertisements";
}

<link rel="stylesheet" href="~/css/advertisements.css" asp-append-version="true" />

@{
    var restaurantStatus = ViewBag.RestaurantStatus as AcctiveStatus?;
    var canCreateAds = ViewBag.CanCreateAds as bool? ?? false;
    
    var totalAds = Model.Count();
    var activeAds = Model.Count(a => a.Status == AdvertisementStatus.Active);
    var pendingAds = Model.Count(a => a.Status == AdvertisementStatus.Pending || a.Status == AdvertisementStatus.PendingPayment);
    var approvedAds = Model.Count(a => a.Status == AdvertisementStatus.Approved);
}

<div class="ads-dashboard">
    <!-- Header -->
    <div class="ads-header">
        <div class="ads-header-content">
            <div>
                <h1 class="ads-title">
                    <i class="bi bi-megaphone-fill"></i>
                    My Advertisements
                </h1>
                <p class="ads-subtitle">Promote your restaurant to reach more customers</p>
            </div>
            <div class="ads-header-actions">
                <a asp-action="Costs" class="ads-btn ads-btn-secondary">
                    <i class="bi bi-graph-up"></i>
                    View Costs
                </a>
                @if (canCreateAds)
                {
                    <a asp-action="Create" class="ads-btn ads-btn-primary">
                        <i class="bi bi-plus-lg"></i>
                        Create New Ad
                    </a>
                }
            </div>
        </div>
    </div>

    @if (!canCreateAds)
    {
        <div class="ads-alert warning">
            <i class="bi bi-exclamation-triangle-fill ads-alert-icon"></i>
            <div class="ads-alert-content">
                <div class="ads-alert-title">Advertisement Creation Disabled</div>
                <p class="ads-alert-text">
                    @switch (restaurantStatus)
                    {
                        case AcctiveStatus.Pending:
                            <text>Your restaurant is pending approval. You will be able to create advertisements once approved.</text>
                            break;
                        case AcctiveStatus.UnAccepted:
                            <text>Please complete your restaurant registration to enable advertisement creation.</text>
                            break;
                        case AcctiveStatus.Block:
                            <text>Your restaurant is currently blocked. Please contact support to resolve this issue.</text>
                            break;
                        case AcctiveStatus.Warning:
                            <text>Your restaurant has a warning status. Please resolve the issues to create new advertisements.</text>
                            break;
                        default:
                            <text>Advertisement creation is currently unavailable. Please contact support.</text>
                            break;
                    }
                </p>
            </div>
        </div>
    }

    <!-- Stats Grid -->
    <div class="ads-stats-grid">
        <div class="ads-stat-card total">
            <div class="ads-stat-icon">
                <i class="bi bi-collection"></i>
            </div>
            <p class="ads-stat-label">Total Ads</p>
            <h3 class="ads-stat-value">@totalAds</h3>
        </div>
        <div class="ads-stat-card active">
            <div class="ads-stat-icon">
                <i class="bi bi-broadcast"></i>
            </div>
            <p class="ads-stat-label">Active</p>
            <h3 class="ads-stat-value">@activeAds</h3>
        </div>
        <div class="ads-stat-card pending">
            <div class="ads-stat-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <p class="ads-stat-label">Pending</p>
            <h3 class="ads-stat-value">@pendingAds</h3>
        </div>
        <div class="ads-stat-card approved">
            <div class="ads-stat-icon">
                <i class="bi bi-check-circle"></i>
            </div>
            <p class="ads-stat-label">Approved</p>
            <h3 class="ads-stat-value">@approvedAds</h3>
        </div>
    </div>

    <!-- Advertisements Table -->
    <div class="ads-table-card">
        <div class="ads-table-header">
            <h2 class="ads-table-title">
                <i class="bi bi-list-ul"></i>
                All Advertisements
            </h2>
        </div>

        @if (!Model.Any())
        {
            <div class="ads-empty-state">
                <i class="bi bi-megaphone"></i>
                <h3>No Advertisements Yet</h3>
                <p>Start promoting your restaurant by creating your first advertisement.</p>
                @if (canCreateAds)
                {
                    <a asp-action="Create" class="ads-btn ads-btn-primary">
                        <i class="bi bi-plus-lg"></i>
                        Create Your First Ad
                    </a>
                }
            </div>
        }
        else
        {
            <div class="ads-table-responsive">
                <table class="ads-table">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Title</th>
                            <th>Plan</th>
                            <th>Status</th>
                            <th>Duration</th>
                            <th>Analytics</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ad in Model.OrderByDescending(a => a.CreatedAt))
                        {
                            <tr>
                                <td>
                                    <img src="@ad.ImageUrl" alt="@ad.Title" class="ads-thumbnail" />
                                </td>
                                <td>
                                    <div class="ads-title-cell">
                                        <strong>@ad.Title</strong>
                                        <small class="text-muted">@ad.TitleAr</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="ads-plan-badge">@ad.PlanName</span>
                                </td>
                                <td>
                                    <span class="ads-status-badge status-@ad.Status.ToString().ToLower()">
                                        @ad.StatusDisplay
                                    </span>
                                </td>
                                <td>
                                    <div class="ads-date-cell">
                                        <span>@ad.StartDate.ToString("MMM dd")</span>
                                        <span class="text-muted">to</span>
                                        <span>@ad.EndDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="ads-analytics-cell">
                                        <span><i class="bi bi-eye"></i> @(ad.Views)</span>
                                        <span><i class="bi bi-hand-index"></i> @(ad.Clicks)</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="ads-actions">
                                        <a asp-action="Details" asp-route-id="@ad.Id" class="ads-action-btn" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (ad.Status == AdvertisementStatus.PendingPayment)
                                        {
                                            <a asp-action="Payment" asp-route-id="@ad.Id" class="ads-action-btn pay" title="Pay Now">
                                                <i class="bi bi-credit-card"></i>
                                            </a>
                                        }
                                        @if (ad.Status == AdvertisementStatus.PendingPayment || ad.Status == AdvertisementStatus.Rejected)
                                        {
                                            <a asp-action="Edit" asp-route-id="@ad.Id" class="ads-action-btn edit" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@ad.Id" method="post" class="d-inline" 
                                                  onsubmit="return confirm('Are you sure you want to delete this advertisement?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="ads-action-btn delete" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        document.querySelectorAll('.alert').forEach(function(alert) {
            setTimeout(function() {
                alert.classList.add('fade');
                setTimeout(function() { alert.remove(); }, 500);
            }, 5000);
        });
    </script>
}
